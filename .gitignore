.env
.env.local
.env.*.local
*.pem
*.key

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
.venv/
venv/
env/
.python-version

# ── Node / React ──
node_modules/
frontend/dist/
frontend/build/
.cache/
*.tsbuildinfo

# ── Model weights & training artifacts ──
*.gguf
*.bin
*.safetensors
*.pt
*.pth
*.onnx
training/outputs/
training/checkpoints/
training/data/qa_pairs/training_data.jsonl
wandb/

# ── Database ──
*.sqlite
*.db
pgdata/

# ── Docker ──
docker-compose.override.yml

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──
*.log
logs/

# ── Misc ──
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
