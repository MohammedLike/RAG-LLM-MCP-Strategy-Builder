# ══════════════════════════════════════════════════════════════
#  Quant AI Agent — Environment Variables
#  Copy this to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ──
POSTGRES_USER=quantagent
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=quantagent
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://quantagent:changeme_strong_password@postgres:5432/quantagent

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── Qdrant ──
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=strategies

# ── Ollama (LLM serving) ──
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL_NAME=mistral:7b-instruct-v0.3-q4_K_M
TEMPERATURE=0.3
MAX_TOKENS=2048

# ── Embedding model ──
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# ── Market data provider ──
# Options: yfinance | nse | broker
MARKET_DATA_PROVIDER=yfinance

# ── Broker API (optional — only if MARKET_DATA_PROVIDER=broker) ──
# BROKER_API_KEY=
# BROKER_API_SECRET=
# BROKER_CLIENT_ID=

# ── FastAPI ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend ──
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# ── Feature flags ──
ENABLE_LIVE_MARKET_DATA=false
ENABLE_FINE_TUNED_MODEL=false
LOG_LEVEL=INFO
